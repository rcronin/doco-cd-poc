# GitHub repo for doco-cd to poll (this repo or your fork).
# Example: https://github.com/YOUR_ORG/doco-cd-poc.git
POLL_REPO_URL=https://github.com/rcronin/doco-cd-poc.git

# Branch or tag to deploy (default: main).
POLL_REF=refs/heads/main

# Poll interval in seconds (default: 120).
POLL_INTERVAL=120

# Optional: GitHub personal access token for private repos or to avoid rate limits.
# Create at: https://github.com/settings/tokens (repo scope for private).
# GIT_ACCESS_TOKEN=ghp_xxxx
GIT_ACCESS_TOKEN=
